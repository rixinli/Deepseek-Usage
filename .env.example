# ============================================
# DeepSeek API 监控 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ============================================

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API Base URL（可选，默认值如下）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 刷新间隔，单位秒（可选，默认 120）
DEEPSEEK_REFRESH_INTERVAL=120
